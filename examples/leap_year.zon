-| Es un Leap Year?, en Zonetic |-

infinity {
    inmut year = readInt("Digita un año: ")

    -| en zonetic tanto and, or, not como &&, ||, y ! son validos nativamente, ambos siendo lo mismo por debajo en el compilador(mismo token) |-
    if (year % 4 == 0) and (year % 100 != 0) || (year % 400 == 0) {
        print("Es un Leap Year")
    } else {
        print("No es un Leap Year")
    }
}
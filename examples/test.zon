-| while form |-
mut i: int = 0
while i < 3 {
    i += 1
}

-| if form |-
if i == 1 {
    print("one")
} elif i == 2 {
    print("two")
} else {
    print("three")
}

-| func form |-
func greet(inmut name: string) -> void {
    print("Hello,", name)
}

greet("Zonetic")

-| struct form |-
struct Point {
    mut x: int = 0
    mut y: int = 0
}

mut p = Point[3, 7]
print("x:", p.x, "y:", p.y)